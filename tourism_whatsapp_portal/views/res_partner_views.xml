<odoo>
    <record id="view_partner_tree_tourism_pending" model="ir.ui.view">
        <field name="name">res.partner.tourism.pending.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="whatsapp_number"/>
                <field name="chatbot_state"/>
                <field name="tourism_approval_state"/>
            </tree>
        </field>
    </record>

    <record id="view_partner_form_tourism_inherit" model="ir.ui.view">
        <field name="name">res.partner.tourism.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Tourism">
                    <group>
                        <field name="is_tourism_provider"/>
                        <field name="whatsapp_number"/>
                        <field name="chatbot_state"/>
                        <field name="tourism_approval_state"/>
                        <field name="cover_image" widget="image"/>
                        <button
                            name="action_approve_provider"
                            type="object"
                            string="Aprobar Prestador"
                            class="btn-primary"
                            invisible="tourism_approval_state != 'pending'"
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_tourism_pending_partners" model="ir.actions.act_window">
        <field name="name">Prestadores pendientes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[("is_tourism_provider", "=", True), ("tourism_approval_state", "=", "pending")]</field>
    </record>

    <menuitem id="menu_tourism_root" name="Tourism" sequence="50"/>
    <menuitem id="menu_tourism_pending_partners" name="Prestadores pendientes" parent="menu_tourism_root" action="action_tourism_pending_partners" sequence="10"/>
</odoo>
