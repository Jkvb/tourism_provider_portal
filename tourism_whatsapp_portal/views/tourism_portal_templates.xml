<odoo>
    <template id="portal_profile_template" name="Tourism Profile">
        <t t-call="website.layout">
            <div class="container py-4">
                <h2>Mi perfil turístico</h2>
                <form action="/my/tourism/profile" method="post" enctype="multipart/form-data" class="mt-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" type="text" name="name" t-att-value="partner.name or ''"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" name="email" t-att-value="partner.email or ''"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input class="form-control" type="text" name="phone" t-att-value="partner.phone or ''"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Foto de portada</label>
                        <input class="form-control" type="file" name="cover_image" accept="image/*"/>
                    </div>
                    <button class="btn btn-primary" type="submit">Guardar</button>
                </form>
            </div>
        </t>
    </template>

    <template id="tourism_feed_template" name="Tourism Feed">
        <t t-call="website.layout">
            <div class="container py-4">
                <h2>Tourism Feed</h2>

                <t t-if="can_post">
                    <div class="card mb-4">
                        <div class="card-body">
                            <form action="/tourism/post/create" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-2">
                                    <textarea class="form-control" name="content" rows="3" placeholder="¿Qué quieres compartir?" required="required"/>
                                </div>
                                <div class="mb-2">
                                    <input class="form-control" type="file" name="image" accept="image/*"/>
                                </div>
                                <button class="btn btn-success" type="submit">Publicar</button>
                            </form>
                        </div>
                    </div>
                </t>

                <div class="row g-3">
                    <t t-foreach="posts" t-as="post">
                        <div class="col-12 col-md-6">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-muted" t-out="post.author_id.name"/>
                                    <p class="card-text" t-out="post.content"/>
                                </div>
                                <t t-if="post.image">
                                    <img class="card-img-bottom" t-att-src="image_data_uri(post.image)" alt="Post image"/>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
