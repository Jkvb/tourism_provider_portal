<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_tourism_admin" model="res.groups">
        <field name="name">Turismo / Administrador</field>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="group_tourism_validator" model="res.groups">
        <field name="name">Turismo / Validador</field>
    </record>

    <record id="tourism_provider_portal_rule_own" model="ir.rule">
        <field name="name">Prestador portal: solo propios</field>
        <field name="model_id" ref="model_tourism_provider"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('portal_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
