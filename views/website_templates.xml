<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tourism_home" name="Turismo - Inicio">
        <t t-call="website.layout">
            <div id="wrap" class="tp-wrap">
                <section class="tp-hero text-white d-flex align-items-center">
                    <div class="container py-5">
                        <div class="row align-items-center">
                            <div class="col-lg-7">
                                <span class="badge rounded-pill bg-light text-dark mb-3">Atemajac de Brizuela</span>
                                <h1 class="display-4 fw-bold mb-3">Descubre experiencias auténticas en la sierra.</h1>
                                <p class="lead mb-4">Explora hospedaje, gastronomía, balnearios y servicios turísticos validados por el municipio.</p>
                                <a class="btn btn-primary btn-lg me-2" href="/turismo/prestadores">Ver prestadores</a>
                                <a class="btn btn-success btn-lg" t-att-href="whatsapp_register_url" target="_blank" rel="noopener">Registrar por WhatsApp</a>
                            </div>
                            <div class="col-lg-5 mt-4 mt-lg-0">
                                <div class="tp-hero-card p-4">
                                    <h5 class="fw-bold">Registro con chatbot WhatsApp</h5>
                                    <p class="mb-2">Comparte esta URL para iniciar por chat:</p>
                                    <code>/turismo/registro</code>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="py-5 bg-white">
                    <div class="container">
                        <h2 class="h3 mb-4">Categorías turísticas</h2>
                        <div class="row g-3">
                            <t t-foreach="categories" t-as="category">
                                <div class="col-md-3 col-sm-6">
                                    <a class="tp-category-card d-block text-decoration-none" t-attf-href="/turismo/prestadores?category_id=#{category.id}">
                                        <div class="d-flex align-items-center gap-2">
                                            <i t-att-class="category.icon or 'fa fa-map-marker'" t-att-style="'color:%s' % (category.color or '#2b6cb0')"/>
                                            <span class="fw-semibold text-dark" t-esc="category.name"/>
                                        </div>
                                        <small class="text-muted" t-esc="category.description or 'Servicios disponibles'"/>
                                    </a>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>

                <section class="py-5 bg-light">
                    <div class="container">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="h3 mb-0">Prestadores destacados</h2>
                            <a href="/turismo/prestadores" class="btn btn-outline-primary">Ver todos</a>
                        </div>
                        <div class="row g-4">
                            <t t-foreach="featured_providers" t-as="provider">
                                <div class="col-lg-4 col-md-6">
                                    <t t-call="tourism_provider_portal.provider_card"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>

                <section class="py-5 bg-white">
                    <div class="container">
                        <div class="tp-register-strip p-4 p-md-5">
                            <h3 class="fw-bold mb-2">¿Eres prestador turístico?</h3>
                            <p class="mb-3">El alta y las actualizaciones ahora se realizan exclusivamente en el chatbot oficial de WhatsApp.</p>
                            <a class="btn btn-success" t-att-href="whatsapp_register_url" target="_blank" rel="noopener">Iniciar registro por WhatsApp</a>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="provider_card" name="Tarjeta prestador">
        <article class="card tp-provider-card h-100 shadow-sm border-0">
            <img t-if="provider.image_1920" t-att-src="image_data_uri(provider.image_1920)" class="card-img-top" alt="imagen"/>
            <div class="card-body">
                <span class="badge bg-primary-subtle text-primary mb-2" t-esc="provider.category_id.name"/>
                <h5 class="card-title mb-1" t-esc="provider.name"/>
                <p class="text-muted small mb-2" t-esc="provider.city or ''"/>
                <p class="card-text" t-esc="(provider.services_description or provider.description or '')[:130]"/>
                <a class="stretched-link text-decoration-none" t-attf-href="/turismo/prestador/#{provider.website_slug}">Conocer más</a>
            </div>
        </article>
    </template>

    <template id="tourism_provider_detail" name="Turismo - Detalle prestador">
        <t t-call="website.layout">
            <div class="container py-4 py-lg-5 tp-profile-page">
                <a href="/turismo/prestadores" class="btn btn-link px-0 mb-3">← Volver al listado</a>

                <section class="tp-cover position-relative rounded-4 overflow-hidden mb-4">
                    <img t-if="provider.cover_image_1920" t-att-src="image_data_uri(provider.cover_image_1920)" class="w-100 h-100 tp-cover-image" alt="Portada"/>
                    <div t-if="not provider.cover_image_1920" class="tp-cover-placeholder"/>
                    <div class="tp-profile-summary position-absolute start-0 bottom-0 p-3 p-md-4 w-100">
                        <div class="d-flex align-items-end gap-3 text-white">
                            <img t-if="provider.profile_image_1920" t-att-src="image_data_uri(provider.profile_image_1920)" class="tp-avatar" alt="Perfil"/>
                            <img t-if="not provider.profile_image_1920 and provider.image_1920" t-att-src="image_data_uri(provider.image_1920)" class="tp-avatar" alt="Perfil"/>
                            <div t-if="not provider.profile_image_1920 and not provider.image_1920" class="tp-avatar tp-avatar-fallback d-flex align-items-center justify-content-center fw-bold">
                                <span t-esc="(provider.name or '?')[:1]"/>
                            </div>
                            <div>
                                <h1 class="h3 mb-1" t-esc="provider.name"/>
                                <p class="mb-0 opacity-75" t-esc="provider.category_id.name"/>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Acerca de</h5>
                                <div t-if="provider.description" t-out="provider.description"/>
                                <p t-if="not provider.description" class="text-muted mb-0">Este prestador aún no agregó una descripción larga.</p>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Servicios</h5>
                                <p class="mb-0" t-esc="provider.services_description or 'Sin servicios capturados todavía.'"/>
                            </div>
                        </div>

                        <div t-if="can_publish_post" class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Publicar una novedad</h5>
                                <form t-attf-action="/my/turismo/prestador/#{provider.id}/post" method="post" enctype="multipart/form-data">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <textarea class="form-control mb-3" rows="3" name="body" placeholder="Ejemplo: Este fin de semana hay promoción familiar." required="required"/>
                                    <div class="d-flex flex-column flex-md-row gap-2 align-items-md-center justify-content-between">
                                        <input class="form-control" type="file" name="post_image" accept="image/*"/>
                                        <button class="btn btn-primary" type="submit">Publicar</button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="mb-0">Publicaciones</h5>
                            <small class="text-muted" t-esc="'%s publicaciones' % len(provider.post_ids)"/>
                        </div>
                        <t t-foreach="provider.post_ids.filtered(lambda p: p.is_published)" t-as="post">
                            <article class="card border-0 shadow-sm mb-3">
                                <div class="card-body">
                                    <p class="mb-2" t-esc="post.body"/>
                                    <img t-if="post.image_1920" t-att-src="image_data_uri(post.image_1920)" class="img-fluid rounded-3 mb-2" alt="Imagen de publicación"/>
                                    <small class="text-muted" t-esc="post.create_date"/>
                                </div>
                            </article>
                        </t>
                        <p t-if="not provider.post_ids" class="text-muted">Aún no hay publicaciones.</p>
                    </div>

                    <aside class="col-lg-4">
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Contacto rápido</h5>
                                <p class="mb-1"><strong>Tel:</strong> <span t-esc="provider.phone or 'No disponible'"/></p>
                                <p class="mb-1"><strong>WhatsApp:</strong> <span t-esc="provider.whatsapp or 'No disponible'"/></p>
                                <p class="mb-1"><strong>Correo:</strong> <span t-esc="provider.email or 'No disponible'"/></p>
                                <p class="mb-1"><strong>Municipio:</strong> <span t-esc="provider.city or 'No disponible'"/></p>
                                <p class="mb-0"><strong>Horarios:</strong> <span t-esc="provider.schedule or 'No disponible'"/></p>
                            </div>
                        </div>

                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Síguenos</h5>
                                <div class="d-flex flex-wrap gap-3">
                                    <a t-if="provider.facebook_url" t-att-href="provider.facebook_url" target="_blank">Facebook</a>
                                    <a t-if="provider.instagram_url" t-att-href="provider.instagram_url" target="_blank">Instagram</a>
                                    <a t-if="provider.tiktok_url" t-att-href="provider.tiktok_url" target="_blank">TikTok</a>
                                    <a t-if="provider.website_url" t-att-href="provider.website_url" target="_blank">Sitio web</a>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">
                                <h5 class="mb-3">Actualizar por chatbot</h5>
                                <p class="text-muted">¿Eres el propietario? Solicita cambios directamente por el chatbot oficial.</p>
                                <a class="btn btn-success w-100" t-att-href="whatsapp_update_url" target="_blank" rel="noopener">Actualizar por WhatsApp</a>
                            </div>
                        </div>

                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="mb-3">Galería</h5>
                                <div class="row g-2">
                                    <t t-foreach="provider.gallery_image_ids" t-as="img">
                                        <div class="col-6">
                                            <img t-att-src="image_data_uri(img.image_1920)" class="img-fluid rounded-3" t-att-alt="img.name"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </t>
    </template>

    <template id="tourism_provider_register" name="Turismo - Registro prestador">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card p-4 p-md-5 shadow-sm border-0 text-center">
                            <h1 class="h2 mb-3">Registro de prestadores turísticos</h1>
                            <p class="text-muted mb-4">Para mejorar adopción, todo el registro ahora se realiza por chatbot de WhatsApp.</p>
                            <ol class="text-start mx-auto mb-4" style="max-width: 520px;">
                                <li>Haz clic en el botón para abrir WhatsApp.</li>
                                <li>Escribe "Hola" y sigue el flujo guiado del chatbot.</li>
                                <li>Comparte datos, evidencias e imágenes solicitadas por el asistente.</li>
                            </ol>
                            <a class="btn btn-success btn-lg" t-att-href="whatsapp_url" target="_blank" rel="noopener">Iniciar registro por WhatsApp</a>
                            <p class="small text-muted mt-3 mb-0">Si no tienes WhatsApp Web, abre este enlace desde tu celular.</p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="tourism_portal_my_providers" name="Portal - Mis prestadores">
        <t t-call="website.layout">
            <div class="container py-5">
                <h1 class="h3 mb-4">Mis prestadores turísticos</h1>
                <a t-att-href="whatsapp_register_url" target="_blank" rel="noopener" class="btn btn-success mb-3">Crear solicitud por WhatsApp</a>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr><th>Nombre</th><th>Categoría</th><th>Estado</th><th>Actualizado</th><th/></tr>
                        </thead>
                        <tbody>
                            <t t-foreach="providers" t-as="provider">
                                <tr>
                                    <td t-esc="provider.name"/>
                                    <td t-esc="provider.category_id.name"/>
                                    <td><span class="badge text-bg-secondary" t-esc="provider.state"/></td>
                                    <td t-esc="provider.write_date"/>
                                    <td><a t-attf-href="/my/turismo/prestador/#{provider.id}">Actualizar por WhatsApp</a></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>

    <template id="tourism_portal_provider_edit" name="Portal - Editar prestador">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card p-4 p-md-5 shadow-sm border-0 text-center">
                            <h1 class="h3 mb-3">Actualizar prestador</h1>
                            <p class="text-muted mb-4">Las actualizaciones de datos del prestador se atienden únicamente por chatbot de WhatsApp para agilizar la revisión.</p>
                            <p class="mb-4"><strong t-esc="provider.name"/></p>
                            <a class="btn btn-success btn-lg" t-att-href="whatsapp_url" target="_blank" rel="noopener">Solicitar actualización por WhatsApp</a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
