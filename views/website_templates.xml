<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <template id="my_tourism_profile" name="My Tourism Profile" page="True">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="mb-4">Mi Perfil Turístico</h2>

                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <form action="/my/tourism/profile/save" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Nombre</label>
                                    <input type="text" class="form-control" name="name" t-att-value="partner.name or ''" required="required"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">WhatsApp</label>
                                    <input type="text" class="form-control" name="whatsapp_number" t-att-value="partner.whatsapp_number or ''"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Teléfono</label>
                                    <input type="text" class="form-control" name="phone" t-att-value="partner.phone or ''"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Portada</label>
                                    <input type="file" class="form-control" name="cover_image" accept="image/*"/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Descripción</label>
                                    <textarea class="form-control" rows="4" name="tourism_profile_description"><t t-out="partner.tourism_profile_description or ''"/></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary mt-3">Guardar Perfil</button>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h4 class="mb-3">Crear publicación</h4>
                        <form action="/my/tourism/post/create" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="mb-3">
                                <textarea name="content" class="form-control" rows="3" placeholder="¿Qué quieres publicar hoy?" required="required"/>
                            </div>
                            <div class="mb-3">
                                <input type="file" class="form-control" name="image" accept="image/*"/>
                            </div>
                            <button type="submit" class="btn btn-success">Publicar</button>
                        </form>
                    </div>
                </div>

                <h4 class="mb-3">Mis publicaciones</h4>
                <t t-foreach="posts" t-as="post">
                    <div class="card shadow-sm mb-3">
                        <div class="card-body">
                            <p class="mb-2"><t t-out="post.content"/></p>
                            <t t-if="post.image">
                                <img t-att-src="image_data_uri(post.image)" class="img-fluid rounded mb-3" alt="Imagen publicación"/>
                            </t>
                            <small class="text-muted d-block mb-3">
                                <t t-out="post.create_date"/>
                            </small>

                            <form class="mb-2" t-att-action="'/my/tourism/post/%s/edit' % post.id" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-2">
                                    <textarea name="content" class="form-control" rows="2" required="required"><t t-out="post.content"/></textarea>
                                </div>
                                <div class="mb-2">
                                    <input type="file" class="form-control" name="image" accept="image/*"/>
                                </div>
                                <button type="submit" class="btn btn-outline-primary btn-sm">Actualizar</button>
                            </form>

                            <form t-att-action="'/my/tourism/post/%s/delete' % post.id" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                            </form>
                        </div>
                    </div>
                </t>
            </div>
        </t>
    </template>

    <template id="tourism_feed" name="Tourism Feed" page="True">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="mb-4">Tourism Feed</h2>
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <t t-foreach="posts" t-as="post">
                            <div class="card shadow-sm mb-4 border-0">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <img t-att-src="image_data_uri(post.author_id.image_1920) if post.author_id.image_1920 else '/web/static/img/placeholder.png'"
                                             class="rounded-circle me-2"
                                             style="width:48px;height:48px;object-fit:cover;"
                                             alt="Foto perfil"/>
                                        <div>
                                            <h6 class="mb-0"><t t-out="post.author_id.name"/></h6>
                                            <small class="text-muted"><t t-out="post.create_date"/></small>
                                        </div>
                                    </div>

                                    <t t-if="post.author_id.cover_image">
                                        <img t-att-src="image_data_uri(post.author_id.cover_image)" class="img-fluid rounded mb-3" alt="Portada"/>
                                    </t>

                                    <p class="mb-3" style="white-space: pre-wrap;"><t t-out="post.content"/></p>

                                    <t t-if="post.image">
                                        <img t-att-src="image_data_uri(post.image)" class="img-fluid rounded" alt="Imagen post"/>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
    </data>
</odoo>
