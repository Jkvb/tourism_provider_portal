<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tourism_category_tree" model="ir.ui.view">
        <field name="name">tourism.provider.category.tree</field>
        <field name="model">tourism.provider.category</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="icon"/>
                <field name="color"/>
                <field name="active"/>
                <field name="provider_count" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="view_tourism_category_form" model="ir.ui.view">
        <field name="name">tourism.provider.category.form</field>
        <field name="model">tourism.provider.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="sequence"/>
                        <field name="icon"/>
                        <field name="color"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tourism_category_search" model="ir.ui.view">
        <field name="name">tourism.provider.category.search</field>
        <field name="model">tourism.provider.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Activas" name="active" domain="[('active','=',True)]"/>
            </search>
        </field>
    </record>

    <record id="action_tourism_category" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">tourism.provider.category</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tourism_category_search"/>
    </record>
</odoo>
