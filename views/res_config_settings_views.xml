<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_whatsapp_turismo_bot" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.whatsapp.turismo.bot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="WhatsApp Turismo Bot" name="whatsapp_turismo_bot">
                    <block title="Cloud API de WhatsApp (Meta)">
                        <setting string="Verify Token">
                            <field name="whatsapp_verify_token" password="True"/>
                        </setting>
                        <setting string="Access Token">
                            <field name="whatsapp_access_token" password="True"/>
                        </setting>
                        <setting string="Phone Number ID">
                            <field name="whatsapp_phone_number_id"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
