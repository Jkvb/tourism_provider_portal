<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tourism_provider_search" model="ir.ui.view">
        <field name="name">tourism.provider.search</field>
        <field name="model">tourism.provider</field>
        <field name="arch" type="xml">
            <search string="Buscar prestadores">
                <field name="name"/>
                <field name="responsible_name"/>
                <field name="signup_email"/>
                <field name="category_id"/>
                <separator/>
                <filter string="Incompletos" name="incomplete" domain="[('state','=','incomplete')]"/>
                <filter string="Pendientes" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Aprobados" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Publicados" name="published" domain="[('state','=','published')]"/>
                <separator/>
                <filter string="Agrupar por categoría" name="group_by_category" context="{'group_by': 'category_id'}"/>
                <filter string="Agrupar por estado" name="group_by_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_tourism_provider_tree" model="ir.ui.view">
        <field name="name">tourism.provider.tree</field>
        <field name="model">tourism.provider</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="signup_email"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="email_confirmed"/>
                <field name="profile_completion"/>
                <field name="review_date"/>
            </list>
        </field>
    </record>

    <record id="view_tourism_provider_form" model="ir.ui.view">
        <field name="name">tourism.provider.form</field>
        <field name="model">tourism.provider</field>
        <field name="arch" type="xml">
            <form string="Prestador turístico">
                <header>
                    <button name="action_submit_review" type="object" string="Enviar a revisión" class="btn-primary" invisible="state not in ('incomplete','draft','rejected','unpublished')"/>
                    <button name="action_approve" type="object" string="Aprobar" class="btn-success" invisible="state != 'pending'" groups="tourism_provider_portal.group_tourism_admin,tourism_provider_portal.group_tourism_validator"/>
                    <button name="action_reject" type="object" string="Rechazar" class="btn-danger" invisible="state != 'pending'" groups="tourism_provider_portal.group_tourism_admin,tourism_provider_portal.group_tourism_validator"/>
                    <button name="action_publish" type="object" string="Publicar" class="btn-success" invisible="state != 'approved'" groups="tourism_provider_portal.group_tourism_admin,tourism_provider_portal.group_tourism_validator"/>
                    <button name="action_unpublish" type="object" string="Despublicar" class="btn-secondary" invisible="state not in ('published','approved')" groups="tourism_provider_portal.group_tourism_admin,tourism_provider_portal.group_tourism_validator"/>
                    <field name="state" widget="statusbar" statusbar_visible="incomplete,pending,approved,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del negocio"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="signup_email"/>
                            <field name="email"/>
                            <field name="email_confirmed" readonly="1"/>
                            <field name="portal_user_id"/>
                            <field name="category_id"/>
                            <field name="responsible_name"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="image_1920" widget="image"/>
                            <field name="profile_image_1920" widget="image"/>
                            <field name="cover_image_1920" widget="image"/>
                            <field name="website_slug" readonly="1"/>
                            <field name="profile_completion" readonly="1"/>
                            <field name="is_published" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Perfil">
                            <group>
                                <field name="description" widget="html"/>
                                <field name="services_description"/>
                                <field name="schedule"/>
                            </group>
                        </page>
                        <page string="Contacto y redes">
                            <group>
                                <group>
                                    <field name="street"/>
                                    <field name="location_reference"/>
                                    <field name="city"/>
                                    <field name="state_id"/>
                                </group>
                                <group>
                                    <field name="facebook_url"/>
                                    <field name="instagram_url"/>
                                    <field name="tiktok_url"/>
                                    <field name="website_url"/>
                                </group>
                            </group>
                        </page>
                        <page string="Publicaciones">
                            <field name="post_ids" context="{'default_provider_id': id}">
                                <list editable="bottom">
                                    <field name="create_date" readonly="1"/>
                                    <field name="author_user_id"/>
                                    <field name="body"/>
                                    <field name="image_1920" widget="image"/>
                                    <field name="is_published"/>
                                </list>
                            </field>
                        </page>
                        <page string="Revisión">
                            <group>
                                <field name="internal_notes"/>
                                <field name="rejection_reason"/>
                                <field name="registration_date" readonly="1"/>
                                <field name="review_user_id" readonly="1"/>
                                <field name="review_date" readonly="1"/>
                                <field name="approval_user_id" readonly="1"/>
                                <field name="approval_date" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tourism_provider" model="ir.actions.act_window">
        <field name="name">Prestadores</field>
        <field name="res_model">tourism.provider</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tourism_provider_search"/>
    </record>

    <record id="action_tourism_provider_pending" model="ir.actions.act_window">
        <field name="name">Solicitudes pendientes</field>
        <field name="res_model">tourism.provider</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','pending')]</field>
        <field name="search_view_id" ref="view_tourism_provider_search"/>
    </record>

    <record id="action_tourism_provider_published" model="ir.actions.act_window">
        <field name="name">Publicados</field>
        <field name="res_model">tourism.provider</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','published')]</field>
        <field name="search_view_id" ref="view_tourism_provider_search"/>
    </record>

    <record id="action_tourism_provider_rejected" model="ir.actions.act_window">
        <field name="name">Rechazados</field>
        <field name="res_model">tourism.provider</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','rejected')]</field>
        <field name="search_view_id" ref="view_tourism_provider_search"/>
    </record>
</odoo>
